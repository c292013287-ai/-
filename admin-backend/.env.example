# 本地开发统一使用 MySQL
# 对应根目录 docker-compose.yml 暴露的 mysql: localhost:3307
DATABASE_URL="mysql://admin:admin123@localhost:3307/resource_admin"

# Docker Compose 容器内连接地址
# DATABASE_URL="mysql://admin:admin123@mysql:3306/resource_admin"

# JWT 密钥（务必修改为随机字符串）
JWT_SECRET=change-me-in-production

# 服务端口
PORT=3001

# 企微 API 基础地址
WECOM_API_BASE="https://qyapi.weixin.qq.com"

# 飞书开放平台应用，用于自动读取用户迁移采集表提交数据
FEISHU_APP_ID=""
FEISHU_APP_SECRET=""
