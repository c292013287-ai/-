generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  name      String
  role      String   @default("admin")
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model WecomEntity {
  id             Int       @id @default(autoincrement())
  name           String
  sku            String?
  rechargeAmount Int       @default(0) @map("recharge_amount")
  monthlyBudget  Int       @default(0) @map("monthly_budget")
  corpid         String
  secret         String
  status         String    @default("active")
  quotaTotal     Int       @default(0) @map("quota_total")
  quotaBalance   Int       @default(0) @map("quota_balance")
  lastSyncAt     DateTime? @map("last_sync_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  records  ConsumptionRecord[]
  syncLogs SyncLog[]
  recharges RechargeRecord[]

  @@map("wecom_entities")
}

model ConsumptionRecord {
  id          Int      @id @default(autoincrement())
  entityId    Int      @map("entity_id")
  date        DateTime
  consumption Int      @default(0)
  calls       Int      @default(0)
  quotaBalance Int     @default(0) @map("quota_balance")
  createdAt   DateTime @default(now()) @map("created_at")

  entity WecomEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, date])
  @@map("consumption_records")
}

model SyncLog {
  id       Int      @id @default(autoincrement())
  entityId Int      @map("entity_id")
  status   String   @default("success")
  message  String?
  syncedAt DateTime @default(now()) @map("synced_at")

  entity WecomEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@map("sync_logs")
}

model RechargeRecord {
  id          Int      @id @default(autoincrement())
  entityId    Int      @map("entity_id")
  amount      Int
  rechargeDate DateTime @map("recharge_date")
  method      String   @default("银行转账")
  remark      String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  entity WecomEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@map("recharge_records")
}
